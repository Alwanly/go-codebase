  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Process",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": 0
    },
    {
      "name": "Launch Package Identity",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/identity",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "9900"
      }
    },
    {
      "name": "Launch Package Core",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/core",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "9901"
      }
    },
    {
      "name": "Launch Package Payment",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/payment",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "9902"
      }
    },
  ]
}%  
